    "#| include: false\n",
    "\n",
    "import pandas as pd\n",
    "import numpy as np\n",
    "import statsmodels.formula.api as smf\n",
    "import seaborn as sns\n",
    "import matplotlib as mpl\n",
    "import matplotlib.pyplot as plt\n",
    "from matplotlib.colors import LinearSegmentedColormap\n",
    "from adjustText import adjust_text\n",
    "\n",
    "sns.set_style('ticks', rc={\n",
    "    'axes.edgecolor': '#888888'\n",
    "})\n",
    "\n",
    "mpl.rcParams.update({\n",
    "    'xtick.color': '#888888',\n",
    "    'ytick.color': '#888888',\n",
    "    'xtick.labelcolor': 'black',\n",
    "    'ytick.labelcolor': 'black',\n",
    "})\n",
    "\n",
    "color_plots = '#4F252E'\n",
    "color_highlight = '#F4AE52'\n",
    "\n",
    "cmap_corr = LinearSegmentedColormap.from_list(\n",
    "    'corr_cmap',\n",
    "    ['#553828', '#FFF', '#314A23']\n",
    ")\n",
    "\n",
    "data_clean = pd.read_csv('data/processed/clean_data.csv')\n",
    "\n",
    "data_latest = data_clean[data_clean['year'] == 2022]\n",
    "outlier_life_exp = min(data_latest['life_expectancy'])\n",
    "data = data_latest[data_latest['life_expectancy'] != outlier_life_exp]\n",
    "data['log_gdp'] = np.log(data['gdp_per_capita'])\n",
    "\n",
    "linear_model = smf.ols(\n",
    "    \"life_expectancy ~ gdp_per_capita\",\n",
    "    data=data\n",
    ").fit()\n",
    "\n",
    "log_gdp_model = smf.ols(\n",
    "    'life_expectancy ~ log_gdp',\n",
    "    data=data\n",
    ").fit()\n",
    "\n",
    "data['daily_vegetables_supply_kg_capita'] = data['daily_vegetables_supply_g_capita']/1000\n",
    "\n",
    "multivariate_model = smf.ols(\n",
    "    'life_expectancy ~ log_gdp + daily_vegetables_supply_kg_capita',\n",
    "    data=data\n",
    ").fit()\n",
    "\n",
    "iqr = data['daily_vegetables_supply_kg_capita'].quantile(0.75) - data['daily_vegetables_supply_kg_capita'].quantile(0.25)\n",
    "\n",
    "upper_bound = data['daily_vegetables_supply_kg_capita'].quantile(0.75) + 1.5 * iqr\n",
    "\n",
    "data['pos_veg_outliers'] = data['daily_vegetables_supply_kg_capita'] > upper_bound"
